# Variáveis de ambiente — copie para .env e preencha os valores

# Banco de Dados
DATABASE_URL=postgresql://viajabem:viajabem@db:5432/viajabem

# Autenticação Admin (JWT)
ADMIN_JWT_SECRET=troque-por-uma-string-aleatoria-de-pelo-menos-32-caracteres
ADMIN_JWT_EXPIRATION_HOURS=8

# OTP — Painel do Líder
OTP_EXPIRATION_MINUTES=10
